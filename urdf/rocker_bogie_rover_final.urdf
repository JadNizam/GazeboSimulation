  </joint>

  <!-- Middle right wheel -->
  <link name="wheel_mr">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.15" length="0.09"/></geometry>
      <material name="tire_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.075" length="0.10"/></geometry>
      <material name="hub_silver"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.035" length="0.12"/></geometry>
      <material name="axle_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.15" length="0.09"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00189" ixy="0.0" ixz="0.0"
               iyy="0.00189" iyz="0.0"
               izz="0.00338"/>
    </inertial>
  </link>

  <joint name="joint_wheel_mr" type="continuous">
    <parent link="right_bogie"/>
    <child link="wheel_mr"/>
    <origin xyz="0.05 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Rear left wheel -->
  <link name="wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.15" length="0.09"/></geometry>
      <material name="tire_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.075" length="0.10"/></geometry>
      <material name="hub_silver"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.035" length="0.12"/></geometry>
      <material name="axle_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.15" length="0.09"/></geometry>
