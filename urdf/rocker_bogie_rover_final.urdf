      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00189" ixy="0.0" ixz="0.0"
               iyy="0.00189" iyz="0.0"
               izz="0.00338"/>
    </inertial>
  </link>

  <joint name="joint_wheel_rr" type="continuous">
    <parent link="right_bogie"/>
    <child link="wheel_rr"/>
    <origin xyz="-0.30 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>


  <!-- Rocker joint spring/damper -->
  <gazebo reference="left_rocker_joint">
    <implicitSpringDamper>1</implicitSpringDamper>
    <springStiffness>50.0</springStiffness>
    <springReference>0.0</springReference>
  </gazebo>
  <gazebo reference="right_rocker_joint">
    <implicitSpringDamper>1</implicitSpringDamper>
    <springStiffness>50.0</springStiffness>
    <springReference>0.0</springReference>
  </gazebo>

  <!-- Gazebo materials -->
  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="left_rocker">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="right_rocker">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="left_bogie">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="right_bogie">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="wheel_fl">
    <material>Gazebo/FlatBlack</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  <gazebo reference="wheel_fr">
    <material>Gazebo/FlatBlack</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  <gazebo reference="wheel_ml">
    <material>Gazebo/FlatBlack</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  <gazebo reference="wheel_mr">
    <material>Gazebo/FlatBlack</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  <gazebo reference="wheel_rl">
    <material>Gazebo/FlatBlack</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>
  <gazebo reference="wheel_rr">
    <material>Gazebo/FlatBlack</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>


  <!-- Diff drive plugin -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">

      <left_joint>joint_wheel_fl</left_joint>
      <left_joint>joint_wheel_ml</left_joint>
      <left_joint>joint_wheel_rl</left_joint>
      <right_joint>joint_wheel_fr</right_joint>
      <right_joint>joint_wheel_mr</right_joint>
      <right_joint>joint_wheel_rr</right_joint>

      <wheel_separation>0.60</wheel_separation>
      <wheel_radial>0.15</wheel_radial>

      <update_rate>50</update_rate>
      <cmd_vel_timeout>0.1</cmd_vel_timeout>
      <max_acceleration>5.0</max_acceleration>
      <max_linear_acceleration>5.0</max_linear_acceleration>
      <max_angular_acceleration>5.0</max_angular_acceleration>
      <max_velocity>3.0</max_velocity>

      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>

      <odom_publish_frequency>50</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>

    </plugin>
  </gazebo>

</robot>
