          <material><ambient>0.58 0.36 0.20 1</ambient><diffuse>0.64 0.40 0.22 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="crater_rim_w">
      <static>true</static>
      <pose>-5.5 -3 0.0 0.15 0.0 0.0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.5 3.0 0.25</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
