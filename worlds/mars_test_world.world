        </visual>
      </link>
    </model>


    <model name="crater_slope_n">
      <static>true</static>
      <pose>-4 -2.0 -0.12 0.25 0.0 0.0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>2.2 1.0 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
