        </visual>
      </link>
    </model>

    <model name="rf_rock_3">
      <static>true</static>
      <pose>4.0 3.8 0.10 0.2 -0.1 0.7</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.40 0.30 0.22</size></box></geometry>
          <surface><friction><ode><mu>0.9</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
