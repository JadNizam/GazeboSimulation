<?xml version="1.0" ?>
<!--
  Mars-like test world for Gazebo Harmonic.
  Terrain built from primitive shapes (no heightmap images or meshes).
  Includes rolling hills, ramp, rock field, crater, and ledge obstacles.
  Flat spawn area at origin.
-->
<sdf version="1.9">
  <world name="mars_test_world">

    <!-- Physics -->
    <physics name="mars_physics" type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>50</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>0.1</contact_max_correcting_vel>
          <contact_surface_layer>0.002</contact_surface_layer>
        </constraints>
      </ode>
      <gravity>0 0 -9.81</gravity>
    </physics>

    <!-- System plugins -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- Scene -->
    <scene>
      <ambient>0.55 0.35 0.25 1.0</ambient>
      <background>0.76 0.50 0.33 1.0</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <fog>
        <color>0.72 0.48 0.32 1.0</color>
        <type>linear</type>
        <start>30.0</start>
        <end>80.0</end>
        <density>0.02</density>
      </fog>
    </scene>

    <!-- Lighting -->
    <!-- Primary sun -->
    <light type="directional" name="mars_sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <diffuse>1.0 0.85 0.65 1.0</diffuse>
      <specular>0.3 0.25 0.18 1.0</specular>
      <attenuation>
        <range>200</range>
        <constant>0.9</constant>
        <linear>0.001</linear>
        <quadratic>0.0</quadratic>
      </attenuation>
      <direction>-0.4 0.3 -0.8</direction>
    </light>

    <!-- Fill light -->
    <light type="directional" name="mars_fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 30 0 0 0</pose>
      <diffuse>0.35 0.22 0.15 1.0</diffuse>
      <specular>0.05 0.03 0.02 1.0</specular>
      <direction>0.5 -0.4 -0.6</direction>
    </light>

    <!-- Ground plane -->
    <model name="mars_ground">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>0.8</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
                <max_vel>0.1</max_vel>
                <min_depth>0.002</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.62 0.38 0.22 1.0</ambient>
            <diffuse>0.68 0.42 0.24 1.0</diffuse>
            <specular>0.05 0.03 0.02 1.0</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Terrain -->

    <!-- Rolling hill 1 -->
    <model name="hill_1">
      <static>true</static>
      <pose>6 5 -0.3 0.08 -0.06 0.2</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6.0 5.0 1.2</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>6.0 5.0 1.2</size></box></geometry>
          <material><ambient>0.58 0.36 0.20 1</ambient><diffuse>0.65 0.40 0.22 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Rolling hill 2 -->
    <model name="hill_2">
      <static>true</static>
      <pose>-7 -6 -0.4 -0.06 0.10 -0.3</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>7.0 4.5 1.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>7.0 4.5 1.0</size></box></geometry>
          <material><ambient>0.60 0.37 0.21 1</ambient><diffuse>0.66 0.41 0.23 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Rolling hill 3 -->
    <model name="hill_3">
      <static>true</static>
      <pose>2 10 -0.5 0.04 -0.03 0.1</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.0 6.0 1.5</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>8.0 6.0 1.5</size></box></geometry>
          <material><ambient>0.56 0.34 0.19 1</ambient><diffuse>0.63 0.39 0.21 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Rolling hill 4 -->
    <model name="hill_4">
      <static>true</static>
      <pose>10 -2 -0.2 0.03 0.07 -0.15</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>5.0 4.0 0.8</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>5.0 4.0 0.8</size></box></geometry>
          <material><ambient>0.61 0.38 0.22 1</ambient><diffuse>0.67 0.42 0.24 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Ridge 1 -->
    <model name="ridge_1">
      <static>true</static>
      <pose>-5 7 -0.1 0.0 0.15 0.4</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6.0 1.0 0.6</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>6.0 1.0 0.6</size></box></geometry>
          <material><ambient>0.55 0.33 0.18 1</ambient><diffuse>0.62 0.38 0.20 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Ridge 2 -->
    <model name="ridge_2">
      <static>true</static>
      <pose>8 -7 -0.1 0.0 -0.12 -0.5</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>5.0 0.8 0.5</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>5.0 0.8 0.5</size></box></geometry>
          <material><ambient>0.57 0.35 0.19 1</ambient><diffuse>0.64 0.40 0.22 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Gentle slope near spawn -->
    <model name="slope_near_spawn">
      <static>true</static>
      <pose>3 0 -0.25 0.0 0.10 0.0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>3.0 3.0 0.5</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>3.0 3.0 0.5</size></box></geometry>
          <material><ambient>0.63 0.39 0.23 1</ambient><diffuse>0.69 0.43 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Steep ramp (~25 deg) -->
    <model name="steep_ramp">
      <static>true</static>
      <pose>5 -3 0.0 0.0 0.0 0.0</pose>
      <link name="link">
        <!-- Ramp surface -->
        <collision name="ramp_col">
          <pose>0 0 0.25 0.0 -0.44 0.0</pose>
          <geometry><box><size>2.5 1.2 0.08</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="ramp_vis">
          <pose>0 0 0.25 0.0 -0.44 0.0</pose>
          <geometry><box><size>2.5 1.2 0.08</size></box></geometry>
          <material><ambient>0.50 0.30 0.16 1</ambient><diffuse>0.55 0.34 0.18 1</diffuse></material>
        </visual>
        <!-- Ramp support -->
        <collision name="support_col">
          <pose>0.4 0 0.15 0.0 0.0 0.0</pose>
          <geometry><box><size>0.8 1.2 0.30</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="support_vis">
          <pose>0.4 0 0.15 0.0 0.0 0.0</pose>
          <geometry><box><size>0.8 1.2 0.30</size></box></geometry>
          <material><ambient>0.45 0.28 0.14 1</ambient><diffuse>0.50 0.30 0.16 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Ramp approach -->
    <model name="ramp_approach">
      <static>true</static>
      <pose>3.6 -3 0.0 0.0 -0.12 0.0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>1.2 1.2 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>1.2 1.2 0.06</size></box></geometry>
          <material><ambient>0.52 0.32 0.17 1</ambient><diffuse>0.57 0.36 0.19 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Rock field -->
    <model name="rockfield_base">
      <static>true</static>
      <pose>3 4 -0.08 0.04 -0.03 0.1</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>4.0 3.5 0.2</size></box></geometry>
          <surface><friction><ode><mu>0.9</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>4.0 3.5 0.2</size></box></geometry>
          <material><ambient>0.55 0.33 0.18 1</ambient><diffuse>0.60 0.37 0.20 1</diffuse></material>
        </visual>
      </link>
    </model>


    <model name="rf_rock_1">
      <static>true</static>
      <pose>2.5 3.5 0.08 0.1 0.2 0.5</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.35 0.25 0.18</size></box></geometry>
          <surface><friction><ode><mu>0.9</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis"><geometry><box><size>0.35 0.25 0.18</size></box></geometry>
          <material><ambient>0.48 0.30 0.15 1</ambient><diffuse>0.52 0.33 0.17 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="rf_rock_2">
      <static>true</static>
      <pose>3.2 4.5 0.06 -0.15 0.3 -0.2</pose>
      <link name="link">
        <collision name="col"><geometry><cylinder><radius>0.15</radius><length>0.20</length></cylinder></geometry>
          <surface><friction><ode><mu>0.9</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
