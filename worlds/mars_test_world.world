    <!-- Landmark A: Tall stone pillar (NE) -->
    <!-- Landmark A: Tall stone pillar (NE) - single model, all sections flush -->
    <model name="landmark_pillar">
      <static>true</static>
      <pose>22 16 0 0.0 0.0 0.3</pose>
      <link name="link">
        <!-- Base disc: center z=0.3, top z=0.6 -->
        <collision name="col_base">
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><cylinder><radius>0.55</radius><length>0.6</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.8</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><max_vel>0.1</max_vel><min_depth>0.002</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis_base">
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><cylinder><radius>0.55</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.35 0.22 0.10 1</ambient><diffuse>0.40 0.25 0.12 1</diffuse></material>
        </visual>
